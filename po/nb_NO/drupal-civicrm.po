#: CRM/Core/Permission.php
msgid "CiviCRM"
msgstr "CiviCRM"

#: CRM/Core/Permission.php
msgid "add contacts"
msgstr "legg til kontakter"

#: CRM/Core/Permission.php
msgid "Create a new contact record in CiviCRM"
msgstr "Lag en ny kontakt i CiviCRM"

#: CRM/Core/Permission.php
msgid "view all contacts"
msgstr "se alle kontakter"

#: CRM/Core/Permission.php
msgid ""
"View ANY CONTACT in the CiviCRM database, export contact info and perform "
"activities such as Send Email, Phone Call, etc."
msgstr "se ENHVER KONTAKT i CiviCRM-databasen, eksporter kontaktinfo og utfør aktiviteter slik som Send epost, Telefonsamtale, o.l."

#: CRM/Core/Permission.php
msgid "edit all contacts"
msgstr "rediger alle kontakter"

#: CRM/Core/Permission.php
msgid ""
"View, Edit and Delete ANY CONTACT in the CiviCRM database; Create and edit "
"relationships, tags and other info about the contacts"
msgstr "se, rediger og slett ENHVER KONTAKT i CiviCRM-databasen; opprett og rediger relasjoner, tagger og annen info om kontaktene"

#: CRM/Core/Permission.php
msgid "view my contact"
msgstr "se min kontakt"

#: CRM/Core/Permission.php
msgid "edit my contact"
msgstr "rediger min kontakt"

#: CRM/Core/Permission.php
msgid "delete contacts"
msgstr "slett kontakter"

#: CRM/Core/Permission.php
msgid "access deleted contacts"
msgstr "tilgang slettede kontakter"

#: CRM/Core/Permission.php
msgid "Access contacts in the trash"
msgstr "tilgang til kontakter i søppelkurven"

#: CRM/Core/Permission.php
msgid "import contacts"
msgstr "importer kontakter"

#: CRM/Core/Permission.php
msgid "Import contacts and activities"
msgstr "importer kontakter og aktiviteter"

#: CRM/Core/Permission.php
msgid "import SQL datasource"
msgstr "importer SQL-datakilde"

#: CRM/Core/Permission.php
msgid "When importing, consume data directly from a SQL datasource"
msgstr "Når du importerer, bruk data direkte fra en SQL-datakilde"

#: CRM/Core/Permission.php
msgid "edit groups"
msgstr "rediger grupper"

#: CRM/Core/Permission.php
msgid ""
"Create new groups, edit group settings (e.g. group name, visibility...), "
"delete groups"
msgstr "lag nye grupper, rediger gruppeinnstillinger (dvs. gruppenavn, synlighet ...), slett grupper"

#: CRM/Core/Permission.php
msgid "administer CiviCRM"
msgstr "administrer CiviCRM"

#: CRM/Core/Permission.php
msgid ""
"Perform all tasks in the Administer CiviCRM control panel and Import "
"Contacts"
msgstr "utfør alle oppgaver i \"Administrer CiviCRM\"-kontrollpanelet, og importer kontakter"

#: CRM/Core/Permission.php
msgid "skip IDS check"
msgstr "hopp over IDS-sjekk"

#: CRM/Core/Permission.php
msgid ""
"Warning: Give to trusted roles only; this permission has security "
"implications. IDS system is bypassed for users with this permission. "
"Prevents false errors for admin users."
msgstr "Advarsel: Gi bare til pålitelige roller, denne tilgangen har sikkerhetsmessige konsekvenser. IDS-systemet blir forbigått for brukere med denne tilgangen. Hindrer falske feil for admin-brukere."

#: CRM/Core/Permission.php
msgid "access uploaded files"
msgstr "tilgang opplastede filer"

#: CRM/Core/Permission.php
msgid "View / download files including images and photos"
msgstr "se / last ned filer, inkludert bilder"

#: CRM/Core/Permission.php
msgid "profile listings and forms"
msgstr "profillister og skjemaer"

#: CRM/Core/Permission.php
msgid ""
"Warning: Give to trusted roles only; this permission has privacy "
"implications. Add/edit data in online forms and access public searchable "
"directories."
msgstr "Advarsel: Gi bare til pålitelige roller, denne tilgangen har sikkerhetsmessige konsekvenser. Legg til/rediger data i nettskjemaer og tilgang til offentlig søkbare mapper."

#: CRM/Core/Permission.php
msgid "profile listings"
msgstr "profillister"

#: CRM/Core/Permission.php
msgid ""
"Warning: Give to trusted roles only; this permission has privacy "
"implications. Access public searchable directories."
msgstr "Advarsel: Gi bare til pålitelige roller, denne tilgangen har personvernkonsekvenser. Tilgang til offentlig søkbare mapper."

#: CRM/Core/Permission.php
msgid "profile create"
msgstr "opprett profil"

#: CRM/Core/Permission.php
msgid "Add data in a profile form."
msgstr "legg til data i et kontaktskjema."

#: CRM/Core/Permission.php
msgid "profile edit"
msgstr "rediger profil"

#: CRM/Core/Permission.php
msgid "Edit data in a profile form."
msgstr "rediger data i et kontaktskjema."

#: CRM/Core/Permission.php
msgid "profile view"
msgstr "se profil"

#: CRM/Core/Permission.php
msgid "View data in a profile."
msgstr "se data i et kontaktskjema."

#: CRM/Core/Permission.php
msgid "access all custom data"
msgstr "tilgang alle tilpassede data"

#: CRM/Core/Permission.php
msgid "View all custom fields regardless of ACL rules"
msgstr "se alle egendefinerte datafelter uavhengig av tilgangsregler"

#: CRM/Core/Permission.php
msgid "view all activities"
msgstr "se alle aktiviteter"

#: CRM/Core/Permission.php
msgid "View all activities (for visible contacts)"
msgstr "se alle aktiviteter (for synlige kontakter)"

#: CRM/Core/Permission.php
msgid "Delete activities"
msgstr "slett activities"

#: CRM/Core/Permission.php
msgid "edit inbound email basic information"
msgstr "rediger grunnleggende informasjon for innkommende e-post"

#: CRM/Core/Permission.php
msgid ""
"Edit all inbound email activities (for visible contacts) basic information. "
"Content editing not allowed."
msgstr "rediger all inbound email activities (for visible contacts) basic information. Content editing not allowed."

#: CRM/Core/Permission.php
msgid "edit inbound email basic information and content"
msgstr "rediger grunnleggende informasjon og innhold for innkommende e-post"

#: CRM/Core/Permission.php
msgid ""
"Edit all inbound email activities (for visible contacts) basic information "
"and content."
msgstr "rediger all inbound email activities (for visible contacts) basic information and content."

#: CRM/Core/Permission.php
msgid "access CiviCRM backend and API"
msgstr "tilgang til CiviCRM-backend og API"

#: CRM/Core/Permission.php
msgid ""
"Master control for access to the main CiviCRM backend and API. Give to "
"trusted roles only."
msgstr "Hovedkontroll for tilgang til CiviCRM og API. Skal kun gis til betrodde roller."

#: CRM/Core/Permission.php
msgid "access Contact Dashboard"
msgstr "tilgang kontaktskrivebord"

#: CRM/Core/Permission.php
msgid "View Contact Dashboard (for themselves and visible contacts)"
msgstr "se kontaktoversikt (for seg selv og synlige kontakter)"

#: CRM/Core/Permission.php
msgid "translate CiviCRM"
msgstr "oversett CiviCRM"

#: CRM/Core/Permission.php
msgid "Allow User to enable multilingual"
msgstr "tillat bruker å aktivere flerspråklig"

#: CRM/Core/Permission.php
msgid "manage tags"
msgstr "administrere tagger"

#: CRM/Core/Permission.php
msgid "Create and rename tags"
msgstr "opprett og endre navn på tagger"

#: CRM/Core/Permission.php
msgid "administer reserved groups"
msgstr "administrer reserverte grupper"

#: CRM/Core/Permission.php
msgid "Edit and disable Reserved Groups (Needs Edit Groups)"
msgstr "rediger og deaktiver reserverte grupper (Trenger rediger grupper)"

#: CRM/Core/Permission.php
msgid "administer Tagsets"
msgstr "administrer tag-sett"

#: CRM/Core/Permission.php
msgid "administer reserved tags"
msgstr "administrer reserverte tagger"

#: CRM/Core/Permission.php
msgid "administer queues"
msgstr "administrer køer"

#: CRM/Core/Permission.php
msgid "Initialize, browse, and cancel background processing queues"
msgstr "initialiser, vis og avbryt køer for bakgrunnsprosessering"

#: CRM/Core/Permission.php
msgid "administer dedupe rules"
msgstr "administrer dublettregler"

#: CRM/Core/Permission.php
msgid "Create and edit rules, change the supervised and unsupervised rules"
msgstr "opprett og rediger regler, og endre overvåkede og ikke-overvåkede regler"

#: CRM/Core/Permission.php
msgid "merge duplicate contacts"
msgstr "flett dupliserte kontakter"

#: CRM/Core/Permission.php
msgid "Delete Contacts must also be granted in order for this to work."
msgstr "Slett kontakter må også være gitt for at dette skal virke"

#: CRM/Core/Permission.php
msgid "force merge duplicate contacts"
msgstr "tving sammenslåing av dupliserte kontakter"

#: CRM/Core/Permission.php
msgid "view debug output"
msgstr "se feilsøkingsdata"

#: CRM/Core/Permission.php
msgid "View results of debug and backtrace"
msgstr "se resultater av feilsøking og tilbakesporing"

#: CRM/Core/Permission.php
msgid "view all notes"
msgstr "se alle notater"

#: CRM/Core/Permission.php
msgid "View notes (for visible contacts) even if they're marked admin only"
msgstr "se notater (for synlige kontakter) selv om de er markert kun for administrator"

#: CRM/Core/Permission.php
msgid "add contact notes"
msgstr "legg til kontaktnotater"

#: CRM/Core/Permission.php
msgid "Create notes for contacts"
msgstr "opprett notater for kontakter"

#: CRM/Core/Permission.php
msgid "access AJAX API"
msgstr "tilgang til  AJAX API"

#: CRM/Core/Permission.php
msgid "Allow API access even if Access CiviCRM is not granted"
msgstr "tillatt API-tilgang selv om ikke tilgang til CiviCRM er gitt"

#: CRM/Core/Permission.php
msgid "access contact reference fields"
msgstr "tilgang til kontaktreferansefelter"

#: CRM/Core/Permission.php
msgid "Allow entering data into contact reference fields"
msgstr "tillat registrering av data i kontaktreferansefelt"

#: CRM/Core/Permission.php
msgid "create manual batch"
msgstr "opprett manuell bunke"

#: CRM/Core/Permission.php
msgid ""
"Create an accounting batch (with Access to CiviContribute and View Own/All "
"Manual Batches)"
msgstr "opprett en regnskapsbunke (med tilgang til CiviGave og vis egne/alle regnskapsbunker)"

#: CRM/Core/Permission.php
msgid "edit own manual batches"
msgstr "rediger egne regnskapsbunker"

#: CRM/Core/Permission.php
msgid "Edit accounting batches created by user"
msgstr "rediger regnskapsbunker opprettet av brukeren"

#: CRM/Core/Permission.php
msgid "edit all manual batches"
msgstr "rediger alle regnskapsbunker"

#: CRM/Core/Permission.php
msgid "Edit all accounting batches"
msgstr "rediger all regnskapsbunker"

#: CRM/Core/Permission.php
msgid "close own manual batches"
msgstr "lukk egne manuelle bunker"

#: CRM/Core/Permission.php
msgid ""
"Close accounting batches created by user (with Access to CiviContribute)"
msgstr "lukk regnskapsbunkene opprettet av brukeren (med tilgang til CiviGave)"

#: CRM/Core/Permission.php
msgid "close all manual batches"
msgstr "lukk alle manuelle bunker"

#: CRM/Core/Permission.php
msgid "Close all accounting batches (with Access to CiviContribute)"
msgstr "lukk alle regnskapsbunker (med tilgang til CiviGave)"

#: CRM/Core/Permission.php
msgid "reopen own manual batches"
msgstr "gjenåpne egne manuelle bunker"

#: CRM/Core/Permission.php
msgid ""
"Reopen accounting batches created by user (with Access to CiviContribute)"
msgstr "gjenåpne regnskapsbunkene opprettet av brukeren (med tilgang til CiviGave)"

#: CRM/Core/Permission.php
msgid "reopen all manual batches"
msgstr "gjenåpne alle manuelle bunker"

#: CRM/Core/Permission.php
msgid "Reopen all accounting batches (with Access to CiviContribute)"
msgstr "gjenåpne alle regnskapsbunker (med tilgang til CiviGave)"

#: CRM/Core/Permission.php
msgid "view own manual batches"
msgstr "se egne manuelle bunker"

#: CRM/Core/Permission.php
msgid ""
"View accounting batches created by user (with Access to CiviContribute)"
msgstr "se regnskapsbunker opprettet av brukeren (med tilgang til CiviGave)"

#: CRM/Core/Permission.php
msgid "view all manual batches"
msgstr "se alle manuelle bunker"

#: CRM/Core/Permission.php
msgid "View all accounting batches (with Access to CiviContribute)"
msgstr "se alle regnskapsbunker (med tilgang til CiviGave)"

#: CRM/Core/Permission.php
msgid "delete own manual batches"
msgstr "slett egne manuelle bunker"

#: CRM/Core/Permission.php
msgid "Delete accounting batches created by user"
msgstr "slett regnskapsbunker opprettet av brukeren"

#: CRM/Core/Permission.php
msgid "delete all manual batches"
msgstr "slett alle manuelle bunker"

#: CRM/Core/Permission.php
msgid "Delete all accounting batches"
msgstr "slett all regnskapsbunker"

#: CRM/Core/Permission.php
msgid "export own manual batches"
msgstr "eksporter egne regnskapsbunker"

#: CRM/Core/Permission.php
msgid "Export accounting batches created by user"
msgstr "eksporter regnskapsbunker opprettet av brukeren"

#: CRM/Core/Permission.php
msgid "export all manual batches"
msgstr "eksporter alle regnskapsbunker"

#: CRM/Core/Permission.php
msgid "Export all accounting batches"
msgstr "eksporter alle regnskapsbunker"

#: CRM/Core/Permission.php
msgid "administer payment processors"
msgstr "administrer betalingsleverandører"

#: CRM/Core/Permission.php
msgid "Add, Update, or Disable Payment Processors"
msgstr "legg til, oppdater eller deaktiver betalingsleverandører"

#: CRM/Core/Permission.php
msgid "render templates"
msgstr "gjengi maler"

#: CRM/Core/Permission.php
msgid ""
"Render open-ended template content. (Additional constraints may apply to "
"autoloaded records and specific notations.)"
msgstr "vis åpent malinnhold. (Ytterligere begrensninger kan gjelde for automatisk lastede poster og spesifikke notasjoner.)"

#: CRM/Core/Permission.php
msgid "edit message templates"
msgstr "rediger meldingsmaler"

#: CRM/Core/Permission.php
msgid "edit system workflow message templates"
msgstr "rediger meldingsmaler for systemarbeidsflyt"

#: CRM/Core/Permission.php
msgid "edit user-driven message templates"
msgstr "rediger brukerstyrte meldingsmaler"

#: CRM/Core/Permission.php
msgid "view my invoices"
msgstr "se egne fakturaer"

#: CRM/Core/Permission.php
msgid "Allow users to view/ download their own invoices"
msgstr "tillat brukere å vise/laste ned sine egne fakturaer"

#: CRM/Core/Permission.php
msgid "edit api keys"
msgstr "rediger api-nøkkel"

#: CRM/Core/Permission.php
msgid "Edit API keys"
msgstr "rediger API-nøkler"

#: CRM/Core/Permission.php
msgid "edit own api keys"
msgstr "rediger egne API-nøkler"

#: CRM/Core/Permission.php
msgid "Edit user's own API keys"
msgstr "rediger brukerens egne API-nøkler"

#: CRM/Core/Permission.php
msgid "send SMS"
msgstr "send SMS"

#: CRM/Core/Permission.php
msgid "Send an SMS"
msgstr "send en SMS"

#: CRM/Core/Permission.php
msgid "administer CiviCRM System"
msgstr "administrer CiviCRM-system"

#: CRM/Core/Permission.php
msgid "Perform all system administration tasks in CiviCRM"
msgstr "utfør alle systemadministrative oppgaver i CiviCRM"

#: CRM/Core/Permission.php
msgid "administer CiviCRM Data"
msgstr "administrer CiviCRM-data"

#: CRM/Core/Permission.php
msgid "Permit altering all restricted data options"
msgstr "tillat endring av alle begrensede datavalg"

#: CRM/Core/Permission.php
msgid "all CiviCRM permissions and ACLs"
msgstr "alle CiviCRM-rettigheter og tilgangskontroller"

#: CRM/Core/Permission.php
msgid ""
"Administer and use CiviCRM bypassing any other permission or ACL checks and "
"enabling the creation of displays and forms that allow others to bypass "
"checks. This permission should be given out with care"
msgstr "administrer og bruk CiviCRM ved å omgå andre tillatelser eller tilgangskontroller, og muliggjør opprettelse av visninger og skjemaer som lar andre omgå kontroller. Denne tillatelsen bør gis med varsomhet."

#: CRM/Core/Permission.php
msgid "administer Multiple Organizations"
msgstr "administrer flere organisasjoner"

#: CRM/Core/Permission.php
msgid ""
"Administer multiple organizations. In practice this allows editing the group"
" organization link"
msgstr "administrer flere organisasjoner. I praksis gir dette mulighet til å redigere koblingen mellom gruppe og organisasjon."
