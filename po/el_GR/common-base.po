#: CRM/Utils/Check/Component/Security.php
msgid "Security Warning"
msgstr "Προειδοποίηση ασφαλείας"

#: CRM/Utils/Check/Component/Security.php
msgid "Files in the data directory (<a %1>%2</a>) should not be downloadable."
msgstr "Τα αρχεία στον κατάλογο δεδομένων (<a %1>%2</a>) δεν πρέπει να μπορούν να ληφθούν."

#: CRM/Utils/Check/Component/Security.php
