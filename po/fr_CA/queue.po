msgstr "Nombre de tentatives autorisées. 0 pour désactiver."

#: schema/Queue/Queue.entityType.php
msgid "Retry Interval"
msgstr "Intervalle entre 2 tentatives"

#: schema/Queue/Queue.entityType.php
