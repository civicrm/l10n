#: CRM/Queue/BAO/Queue.php
msgid "Aborted"
msgstr "Anulat"

#: CRM/Queue/BAO/Queue.php
msgid "Delete failed tasks"
msgstr "Șterge sarcinile eșuate"

#: CRM/Queue/BAO/Queue.php
msgid "Abort the queue-runner"
msgstr "Oprește executorul de coadă"

#: CRM/Queue/BAO/Queue.php
msgid "Memory (Linear)"
msgstr "Memorie (Liniară)"

#: CRM/Queue/BAO/Queue.php
msgid "SQL (Linear)"
msgstr "SQL (Liniar)"

#: CRM/Queue/BAO/Queue.php
msgid "SQL (Parallel)"
msgstr "SQL (Paralel)"

#: CRM/Queue/Page/Monitor.php
msgid "Queue Monitor \"%1\""
msgstr "Monitor coadă \"%1\""

#: CRM/Queue/Page/Runner.php
msgid "Queue runner must be configured before execution."
msgstr "Executorul de coadă trebuie configurat înainte de execuție."

#: CRM/Queue/Runner.php
msgid "Queue Runner"
msgstr "Executorul de coadă"

#: schema/Queue/Queue.entityType.php
msgid "Queues"
msgstr "Cozi"

#: schema/Queue/Queue.entityType.php
msgid "Stores a list of persistent queues"
msgstr "Stochează o listă de cozi persistente"

#: schema/Queue/Queue.entityType.php
msgid "System Queue ID"
msgstr "ID coadă sistem"

#: schema/Queue/Queue.entityType.php
msgid "Name of the queue"
msgstr "Numele cozii"

#: schema/Queue/Queue.entityType.php
msgid "Type of the queue"
msgstr "Tipul cozii"

#: schema/Queue/Queue.entityType.php
msgid "Runner"
msgstr "Executor"

#: schema/Queue/Queue.entityType.php
msgid "Name of the task runner"
msgstr "Numele executorului de sarcini"

#: schema/Queue/Queue.entityType.php
msgid "Maximum number of items in a batch."
msgstr "Numărul maxim de elemente dintr-un lot."

#: schema/Queue/Queue.entityType.php
msgid "Lease Time"
msgstr "Timp de rezervare"

#: schema/Queue/Queue.entityType.php
msgid ""
"When claiming an item (or batch of items) for work, how long should the "
"item(s) be reserved. (Seconds)"
msgstr "La preluarea unui element (sau lot de elemente) pentru procesare, cât timp ar trebui să fie rezervat(e). (Secunde)"

#: schema/Queue/Queue.entityType.php
msgid "Retry Limit"
msgstr "Limită de reîncercări"

#: schema/Queue/Queue.entityType.php
msgid "Number of permitted retries. Set to zero (0) to disable."
msgstr "Numărul de reîncercări permise. Setați la zero (0) pentru a dezactiva."

#: schema/Queue/Queue.entityType.php
msgid "Retry Interval"
msgstr "Interval de reîncercare"

#: schema/Queue/Queue.entityType.php
msgid "Number of seconds to wait before retrying a failed execution."
msgstr "Numărul de secunde de așteptat înainte de a reîncerca o execuție eșuată."

#: schema/Queue/Queue.entityType.php
msgid "Execution status"
msgstr "Status execuție"

#: schema/Queue/Queue.entityType.php
msgid "Error Mode"
msgstr "Mod eroare"

#: schema/Queue/Queue.entityType.php
msgid "Fallback behavior for unhandled errors"
msgstr "Comportament de rezervă pentru erorile negestionate"

#: schema/Queue/Queue.entityType.php
msgid "Is this a template configuration (for use by other/future queues)?"
msgstr "Aceasta este o configurație șablon (pentru utilizare de către alte cozi/cozi viitoare)?"

#: schema/Queue/QueueItem.entityType.php
msgid "Queue Item"
msgstr "Element coadă"

#: schema/Queue/QueueItem.entityType.php
msgid "Queue Items"
msgstr "Elemente coadă"

#: schema/Queue/QueueItem.entityType.php
msgid "Stores a list of queue items"
msgstr "Stochează o listă de elemente din coadă"

#: schema/Queue/QueueItem.entityType.php
msgid "Queue Item ID"
msgstr "ID element coadă"

#: schema/Queue/QueueItem.entityType.php
msgid "Queue Name"
msgstr "Numele cozii"

#: schema/Queue/QueueItem.entityType.php
msgid "Name of the queue which includes this item"
msgstr "Numele cozii care include acest element"

#: schema/Queue/QueueItem.entityType.php
msgid "Submit Time"
msgstr "Timp de trimitere"

#: schema/Queue/QueueItem.entityType.php
msgid "date on which this item was submitted to the queue"
msgstr "data la care acest element a fost trimis în coadă"

#: schema/Queue/QueueItem.entityType.php
msgid "Release Time"
msgstr "Timp de eliberare"

#: schema/Queue/QueueItem.entityType.php
msgid "date on which this job becomes available; null if ASAP"
msgstr "data la care această sarcină devine disponibilă; nul dacă este cât mai curând posibil"

#: schema/Queue/QueueItem.entityType.php
msgid "Run Count"
msgstr "Număr de rulări"

#: schema/Queue/QueueItem.entityType.php
msgid "Number of times execution has been attempted."
msgstr "Numărul de ori în care execuția a fost încercată."

#: schema/Queue/QueueItem.entityType.php
msgid "Queue item data"
msgstr "Datele elementului din coadă"

#: schema/Queue/QueueItem.entityType.php
msgid "Serialized queue data"
msgstr "Date din coadă înseriate"
